<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="HomeWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#6B7280</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="HomeDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/home_day_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="HomeDayMuted" parent="HomeDay">
        <item name="android:textColor">#C4CBD5</item>
    </style>

    <style name="HomeDayWeekend" parent="HomeDay">
        <item name="android:textColor">#FF6600</item>
    </style>

    <style name="HomeDayActive" parent="HomeDay">
        <item name="android:background">@drawable/home_day_active_bg</item>
    </style>

    <style name="HomeDotOrange">
        <item name="android:layout_width">7dp</item>
        <item name="android:layout_height">7dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:background">@drawable/home_dot_orange</item>
    </style>

    <style name="HomeDotGreen" parent="HomeDotOrange">
        <item name="android:background">@drawable/home_dot_green</item>
    </style>

    <style name="HomeDotPurple" parent="HomeDotOrange">
        <item name="android:background">@drawable/home_dot_purple</item>
    </style>

    <style name="HomeLegend">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:textColor">#6B7280</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="HomeShortcut">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/home_card_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#0066A6</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="HomePanelTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#1F2937</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="HomeCourseRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">#374151</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
