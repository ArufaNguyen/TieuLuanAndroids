<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_dialog_bg"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_height="wrap_content">

        <View
            android:layout_width="150dp"
            android:layout_height="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#D3D3D3" />

        <TextView
            android:id="@+id/text_tag_manager_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quản lý chủ đề"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Khu vực thêm chủ đề mới -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edt_new_topic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập chủ đề mới (VD: đi chơi, đi ngủ...)"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_add_topic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Thêm"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Danh sách chủ đề hiện có, được sinh động theo ArrayList -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="320dp">

            <LinearLayout
                android:id="@+id/layout_topic_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <TextView
            android:id="@+id/text_topic_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Chưa có chủ đề nào. Hãy thêm chủ đề đầu tiên!"
            android:textColor="#888888"
            android:visibility="gone"
            tools:visibility="visible" />

        <Button
            android:id="@+id/btn_close_topic_manager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đóng"
            android:textAllCaps="false" />

    </LinearLayout>
</FrameLayout>