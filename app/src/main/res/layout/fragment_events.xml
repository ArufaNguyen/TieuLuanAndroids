<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_page_bg"
    android:fillViewport="true"
    tools:context=".ui.events.EventsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_events_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/events_title"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Theo doi lich hoc, lich thi va cac su kien da dong bo."
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/card_event_editor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_event_editor_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sua su kien"
                android:textColor="#1F2937"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_event_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Chon mot su kien de sua"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edt_event_description"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_chip_bg"
                android:gravity="top"
                android:hint="Mo ta"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:padding="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <Spinner
                android:id="@+id/spinner_event_tag"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/edt_event_start_time"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Thoi gian bat dau"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edt_event_end_time"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Thoi gian ket thuc"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_save_event_edit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Luu"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_clear_event_edit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Lam moi"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_delete_event_edit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D93025"
                android:text="Xoa"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Danh sach su kien"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/button_refresh_events"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/events_refresh"
                    android:textAllCaps="false"
                    android:textSize="12sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/edt_search_events"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Tim su kien hoac tag"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_event_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/events_loading"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/list_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/text_event_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:padding="18dp"
                android:text="@string/events_empty"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_close_events"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Dong"
            android:textAllCaps="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>