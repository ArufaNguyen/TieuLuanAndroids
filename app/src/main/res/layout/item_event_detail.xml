<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/event_detail_card_bg"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/text_event_detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_event_detail_tag"
        style="@style/EventDetailLine"
        android:clickable="true"
        android:focusable="true"
        android:text="Tag: -"
        android:textColor="#0066A6" />

    <TextView
        android:id="@+id/text_event_detail_time"
        style="@style/EventDetailLine"
        android:text="Thoi gian: -" />

    <TextView
        android:id="@+id/text_event_detail_detail"
        style="@style/EventDetailLine"
        android:clickable="true"
        android:focusable="true"
        android:text="Chi tiet"
        android:textColor="#0066A6" />
</LinearLayout>
