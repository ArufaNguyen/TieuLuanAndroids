                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:divider="?android:attr/listDivider"
                android:showDividers="middle">

                <TextView android:id="@+id/text_monday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Mon" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_tuesday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Tue" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_wednesday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Wed" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_thursday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Thu" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_friday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Fri" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_saturday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Sat" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
                <TextView android:id="@+id/text_sunday_header" android:layout_width="240dp" android:layout_height="match_parent" android:text="Sun" android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:background="@drawable/cell_border"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
