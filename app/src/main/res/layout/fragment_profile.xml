<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_title"
                android:textColor="#1F2937"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_profile_status"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/home_chip_bg"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Dang cap nhat"
                android:textColor="#0066A6"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="#E4EAF2" />

            <TextView
                style="@style/HomePanelTitle"
                android:text="Ho ten" />

            <TextView
                android:id="@+id/text_profile_full_name"
                style="@style/ProfileValue"
                android:text="-" />

            <TextView
                style="@style/HomePanelTitle"
                android:layout_marginTop="14dp"
                android:text="Username" />

            <TextView
                android:id="@+id/text_profile_username"
                style="@style/ProfileValue"
                android:text="-" />

            <TextView
                style="@style/HomePanelTitle"
                android:layout_marginTop="14dp"
                android:text="Email" />

            <TextView
                android:id="@+id/text_profile_email"
                style="@style/ProfileValue"
                android:text="-" />

            <TextView
                style="@style/HomePanelTitle"
                android:layout_marginTop="14dp"
                android:text="Ma tai khoan" />

            <TextView
                android:id="@+id/text_profile_user_id"
                style="@style/ProfileValue"
                android:text="-" />

            <TextView
                style="@style/HomePanelTitle"
                android:layout_marginTop="14dp"
                android:text="Het han session" />

            <TextView
                android:id="@+id/text_profile_expires"
                style="@style/ProfileValue"
                android:text="-" />

            <Button
                android:id="@+id/button_profile_login"
                style="@style/HomeShortcut"
                android:layout_width="match_parent"
                android:layout_marginTop="18dp"
                android:text="Login" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
